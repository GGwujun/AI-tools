.page { min-height: 100vh; background:#f7f8fa; }
.scroll { height:100vh; padding:20rpx 24rpx 32rpx; box-sizing:border-box; }
.hero-card, .section-card { border-radius:28rpx; background:#fff; box-shadow:0 12rpx 32rpx rgba(16,24,40,0.06); }
.hero-card { padding:28rpx 24rpx; }
.hero-title { display:block; color:#101828; font-size:34rpx; font-weight:700; }
.hero-desc { display:block; margin-top:14rpx; color:#667085; font-size:24rpx; line-height:1.8; }
.section-card { margin-top:18rpx; padding:24rpx; }
.section-title { display:block; color:#101828; font-size:28rpx; font-weight:700; }
.section-body { display:block; margin-top:12rpx; color:#667085; font-size:24rpx; line-height:1.8; }
.primary-btn { margin-top:24rpx; height:84rpx; border-radius:20rpx; background:#1565ff; color:#fff; font-size:28rpx; font-weight:600; line-height:1; display:flex; align-items:center; justify-content:center; }
.primary-btn::after { border:none; }
