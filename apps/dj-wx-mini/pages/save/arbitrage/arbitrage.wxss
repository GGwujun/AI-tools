.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 120rpx;
  box-sizing: border-box;
}

/* 更新时间 */
.update-time {
  background: linear-gradient(135deg, #667eea, #764ba2);
  padding: 20rpx 30rpx;
  font-size: 24rpx;
  color: #fff;
  text-align: center;
}

/* Tab切换栏 */
.tab-bar {
  display: flex;
  background: #fff;
  padding: 0 10rpx;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  position: relative;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 50%;
  height: 4rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 2rpx;
}

.tab-text {
  font-size: 26rpx;
  color: #666;
}

.tab-item.active .tab-text {
  color: #667eea;
  font-weight: 600;
}

/* 内容区域 */
.content {
  padding: 20rpx 20rpx 20rpx 20rpx;
  height: calc(100vh - 200rpx);
  box-sizing: border-box;
}

/* 表格卡片 */
.table-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

/* Tab说明 */
.tab-desc {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  margin-top: 16rpx;
}

.tab-desc-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.tab-desc-text {
  flex: 1;
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

/* 基金购买说明 */
.fund-notes {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-top: 16rpx;
}

.fund-notes-title {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
}

.fund-note-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 8rpx;
}

.fund-note-item:last-child {
  margin-bottom: 0;
}

.note-bullet {
  font-size: 24rpx;
  color: #ff9800;
  margin-right: 10rpx;
}

.note-text {
  flex: 1;
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

/* 表头 */
.table-header {
  display: flex;
  background: linear-gradient(135deg, #667eea, #764ba2);
  padding: 24rpx 20rpx;
}

.th {
  font-size: 24rpx;
  color: #fff;
  text-align: center;
  font-weight: 600;
}

.th-name {
  flex: 2;
  text-align: left;
}

.th-premium {
  flex: 1;
}

.th-price {
  flex: 1;
}

.th-star {
  flex: 0.6;
}

.sort-icon {
  margin-left: 4rpx;
  font-size: 20rpx;
}

/* 数据行 */
.table-body {
  padding: 0 20rpx;
}

.table-row {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.table-row:last-child {
  border-bottom: none;
}

.table-row.paused {
  background: #f5f5f5;
}

.td {
  text-align: center;
}

.td-name {
  flex: 2;
  text-align: left;
  display: flex;
  flex-direction: column;
}

.fund-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  display: block;
  margin-bottom: 4rpx;
}

.fund-code {
  font-size: 22rpx;
  color: #999;
  display: block;
}

.fund-red {
  font-size: 20rpx;
  color: #ff4d4f;
  display: block;
  margin-top: 4rpx;
}

.td-premium {
  flex: 1;
}

.premium-value {
  font-size: 28rpx;
  font-weight: bold;
}

.td-premium.up .premium-value {
  color: #52c41a;
}

.td-premium.down .premium-value {
  color: #ff4d4f;
}

.td-price {
  flex: 1;
}

.price-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.td-star {
  flex: 0.6;
}

.star-icon {
  font-size: 40rpx;
  color: #ccc;
}

.star-icon.starred {
  color: #ff9800;
}

/* 数量统计栏 */
.stats-bar {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  margin-top: 20rpx;
}

.stats-count {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.stats-tip {
  flex: 1;
  font-size: 24rpx;
  color: #666;
}

.stats-link {
  font-size: 24rpx;
  color: #667eea;
}

/* 会员卡片 */
.member-card {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #ff9800, #ff5722);
  padding: 24rpx;
  border-radius: 12rpx;
  margin-top: 16rpx;
}

.member-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.member-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

/* 免责声明 */
.disclaimer {
  padding: 20rpx 0;
}

.disclaimer text {
  display: block;
  font-size: 22rpx;
  color: #999;
  text-align: center;
  line-height: 1.6;
}

/* 红色分数说明 */
.explain-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-top: 16rpx;
}

.explain-title {
  font-size: 26rpx;
  color: #ff4d4f;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.explain-text {
  font-size: 24rpx;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.explain-desc {
  font-size: 22rpx;
  color: #999;
  display: block;
  line-height: 1.5;
}

/* 最强攻略 */
.guide-card {
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-top: 16rpx;
}

.guide-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.guide-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.guide-title {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

.guide-item {
  display: flex;
  align-items: flex-start;
  padding: 10rpx 0;
}

.guide-arrow {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
  margin-right: 10rpx;
}

.guide-content {
  flex: 1;
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
  line-height: 1.5;
}

/* 功能说明 */
.tips-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-top: 16rpx;
}

.tips-title {
  font-size: 26rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.tips-item {
  font-size: 24rpx;
  color: #666;
  line-height: 1.8;
  display: block;
}

/* 全球指数 */
.indices-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-top: 16rpx;
}

.indices-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.indices-row {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.indices-item {
  flex: 1;
  min-width: 50%;
  padding: 8rpx 0;
}

.indices-label {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 4rpx;
}

.indices-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 600;
  display: block;
}

.indices-change {
  font-size: 22rpx;
  display: block;
}

.indices-change.up {
  color: #52c41a;
}

.indices-change.down {
  color: #ff4d4f;
}

.indices-footer {
  text-align: right;
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 灰底说明 */
.gray-tip {
  padding: 20rpx 0;
}

.gray-tip text {
  font-size: 22rpx;
  color: #999;
  display: block;
  text-align: center;
}
