<view class="page">
  <!-- 更新时间 -->
  <view class="update-time">更新时间: {{updateTime}}</view>

  <!-- Tab切换 -->
  <view class="tab-bar">
    <view class="tab-item {{currentTab == index ? 'active' : ''}}"
          wx:for="{{tabs}}" wx:key="index"
          bindtap="onTabChange" data-index="{{index}}">
      <text class="tab-text">{{item}}</text>
    </view>
  </view>

  <!-- 基金列表 -->
  <scroll-view scroll-y class="content">
    <view class="table-card">
      <!-- 表头 -->
      <view class="table-header">
        <view class="th th-name" bindtap="onSort" data-field="name">
          基金名称
          <text class="sort-icon" wx:if="{{sortField == 'name'}}">{{sortOrder == 'desc' ? '↓' : '↑'}}</text>
        </view>
        <view class="th th-premium" bindtap="onSort" data-field="premium">
          溢价率
          <text class="sort-icon" wx:if="{{sortField == 'premium'}}">{{sortOrder == 'desc' ? '↓' : '↑'}}</text>
        </view>
        <view class="th th-price">场内价格</view>
        <view class="th th-star" bindtap="onSort" data-field="starred">
          自选
          <text class="sort-icon" wx:if="{{sortField == 'starred'}}">{{sortOrder == 'desc' ? '↓' : '↑'}}</text>
        </view>
      </view>

      <!-- 数据行 -->
      <view class="table-body">
        <view class="table-row {{item.paused ? 'paused' : ''}}" wx:for="{{fundList}}" wx:key="code" bindtap="onFundTap" data-index="{{index}}">
          <view class="td td-name">
            <text class="fund-name">{{item.name}}</text>
            <text class="fund-code">{{item.code}}</text>
            <text class="fund-red" wx:if="{{item.downDays > 0}}">{{item.downDays}}/{{item.maxDownDays}}</text>
          </view>
          <view class="td td-premium {{item.up ? 'up' : 'down'}}">
            <text class="premium-value">{{item.premium}}</text>
          </view>
          <view class="td td-price">
            <text class="price-value">{{item.price}}</text>
          </view>
          <view class="td td-star" catchtap="onStar" data-index="{{index}}">
            <text class="star-icon {{item.starred ? 'starred' : ''}}">
              {{item.starred ? '★' : '☆'}}
            </text>
          </view>
        </view>
      </view>
    </view>

    <!-- Tab说明 -->
    <view class="tab-desc">
      <text class="tab-desc-icon">💡</text>
      <text class="tab-desc-text">{{tabDescs[currentTab]}}</text>
    </view>

    <!-- 基金购买说明 -->
    <view class="fund-notes">
      <text class="fund-notes-title">{{currentNote}}</text>
      <view class="fund-note-item" wx:for="{{currentSpecialNotes}}" wx:key="index">
        <text class="note-bullet">•</text>
        <text class="note-text">{{item}}</text>
      </view>
    </view>

    <!-- 数量统计 -->
    <view class="stats-bar">
      <text class="stats-count">{{fundList.length}}只</text>
      <text class="stats-tip">数量不够多?需要添加基金?</text>
      <text class="stats-link">去看看会员功能 →</text>
    </view>

    <!-- 会员提醒 -->
    <view class="member-card">
      <text class="member-icon">💎</text>
      <text class="member-text">去开启套利提醒</text>
    </view>

    <!-- 免责声明 -->
    <view class="disclaimer">
      <text>数据仅供参考，不构成任何投资建议。</text>
      <text>数据有一定的延时，仅供参考，请确认顶部更新时间。</text>
    </view>

    <!-- 红色分数说明 -->
    <view class="explain-card">
      <view class="explain-title">基金名称下方的红色分数含义:</view>
      <text class="explain-text">当前连续下跌天数/历史最大连续下跌天数</text>
      <text class="explain-desc">仅供抄底/套利参考，只有在连续下跌超过一定天数后该指标才会出现</text>
    </view>

    <!-- 最强攻略 -->
    <view class="guide-card">
      <view class="guide-header">
        <text class="guide-icon">📚</text>
        <text class="guide-title">最强攻略文章，没看就别说自己不会!</text>
      </view>
      <view class="guide-item">
        <text class="guide-arrow">▶</text>
        <text class="guide-content">最强基金干货，直接解决你99%的疑惑</text>
      </view>
      <view class="guide-item">
        <text class="guide-arrow">▶</text>
        <text class="guide-content">场外基金怎么转入场内吃溢价，最详实操教程</text>
      </view>
    </view>

    <!-- 功能说明 -->
    <view class="tips-card">
      <view class="tips-title">💡 功能说明</view>
      <view class="tips-item">神秘功能: 蓝色表头点击可以切换，加自选。</view>
      <view class="tips-item">不拖: 不能使用拖拉机，按身份证限额。</view>
      <view class="tips-item">场外: 只能场外申购转场内吃溢价。</view>
    </view>

    <!-- 全球指数 -->
    <view class="indices-card">
      <view class="indices-title">🌍 全球市场</view>
      <view class="indices-row">
        <view class="indices-item">
          <text class="indices-label">美元兑人民币中间价</text>
          <text class="indices-value">6.8654</text>
          <text class="indices-change up">(+0.0073%)</text>
        </view>
        <view class="indices-item">
          <text class="indices-label">美元兑离岸人民币</text>
          <text class="indices-value">6.8318</text>
          <text class="indices-change up">(+0.063%)</text>
        </view>
      </view>
      <view class="indices-row">
        <view class="indices-item">
          <text class="indices-label">纳斯达克指数期货</text>
          <text class="indices-value">25226.67</text>
          <text class="indices-change down">(-0.1%)</text>
        </view>
        <view class="indices-item">
          <text class="indices-label">标普500指数期货</text>
          <text class="indices-value">6857.37</text>
          <text class="indices-change down">(-0.09%)</text>
        </view>
      </view>
      <view class="indices-row">
        <view class="indices-item">
          <text class="indices-label">印度孟买SENSEX</text>
          <text class="indices-value">77383.31</text>
          <text class="indices-change up">(+0.98%)</text>
        </view>
      </view>
      <view class="indices-footer">
        <text>更新: 10日 16:09分</text>
      </view>
    </view>

    <!-- 灰底说明 -->
    <view class="gray-tip">
      <text>💡 如果是灰底，说明该基金今日暂停申购。</text>
    </view>
  </scroll-view>
</view>
