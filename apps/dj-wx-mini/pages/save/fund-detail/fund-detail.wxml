<view class="page">
  <!-- 顶部标题 -->
  <view class="header">
    <view class="header-title-row">
      <text class="fund-name">{{fund.name}}</text>
      <text class="fund-lof">LOF</text>
      <text class="fund-code">{{fund.code}}</text>
    </view>
    <text class="header-time">更新时间: {{updateTime}}</text>
  </view>

  <!-- 警告横幅 -->
  <view class="warning-banner" wx:if="{{fund.paused}}">
    <text class="warning-icon">⚠️</text>
    <text class="warning-text">基金暂停申购，请谨慎操作</text>
  </view>

  <!-- 价格信息卡片 -->
  <view class="price-card">
    <view class="price-main">
      <view class="price-left">
        <text class="price-label">当前价格</text>
        <view class="price-value-row">
          <text class="price-value">{{fund.price}}</text>
          <text class="price-change {{fund.up ? 'up' : 'down'}}">{{fund.up ? '↑' : '↓'}} {{fund.change || '+2.09%'}}</text>
        </view>
      </view>
      <view class="price-divider"></view>
      <view class="price-right">
        <text class="price-label">实时净值(IOPV)</text>
        <text class="price-iopt">1.4806</text>
      </view>
    </view>
    <!-- 下跌天数 -->
    <view class="down-days-row" wx:if="{{fund.downDays > 0}}">
      <view class="down-badge">
        <text class="down-red">{{fund.downDays}}/{{fund.maxDownDays}}</text>
      </view>
      <text class="down-desc">连续下跌天数超过历史最大{{fund.maxDownDays}}天，当前仅{{fund.downDays}}天，套利空间较小</text>
    </view>
  </view>

  <!-- 规模与成交 -->
  <view class="scale-card">
    <view class="scale-item">
      <text class="scale-label">总规模</text>
      <text class="scale-value">{{scale}}</text>
    </view>
    <view class="scale-divider"></view>
    <view class="scale-item">
      <text class="scale-label">成交额</text>
      <text class="scale-value">{{turnover}}</text>
    </view>
  </view>

  <!-- 溢价信息卡片 -->
  <view class="premium-card">
    <view class="premium-main">
      <view class="premium-rate">
        <text class="premium-label">溢价率</text>
        <text class="premium-value {{fund.up ? 'up' : 'down'}}">{{fund.premium}}</text>
      </view>
      <view class="premium-divider"></view>
      <view class="premium-info">
        <view class="info-item">
          <text class="info-label">估算收益</text>
          <text class="info-value">{{estimatedProfit}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">套利空间</text>
          <text class="info-value">{{arbitrageSpace}}</text>
        </view>
      </view>
    </view>
    <view class="premium-warning">
      <text class="warning-title">⚠️ {{riskTitle}}</text>
      <text class="warning-desc">{{riskDesc}}</text>
    </view>
  </view>

  <!-- 五档折溢价 -->
  <view class="five-level-card">
    <view class="five-level-header">
      <text class="five-level-title">实时五档折溢价</text>
      <text class="five-level-time">更新时间: {{fiveLevel.updateTime}}</text>
    </view>
    <!-- 卖五档 -->
    <view class="five-level-section">
      <view class="five-level-section-title">卖(溢价)</view>
      <view class="five-level-row header-row">
        <text class="five-level-col-title">价格</text>
        <text class="five-level-col-title">成交量</text>
        <text class="five-level-col-title">折溢价率</text>
      </view>
      <view class="five-level-row" wx:for="{{fiveLevel.ask}}" wx:key="index">
        <text class="five-level-price ask">{{item.price}}</text>
        <text class="five-level-vol">{{item.volume}}</text>
        <text class="five-level-premium up">{{item.premium}}</text>
      </view>
    </view>
    <!-- 买五档 -->
    <view class="five-level-section">
      <view class="five-level-section-title">买(折价)</view>
      <view class="five-level-row header-row">
        <text class="five-level-col-title">价格</text>
        <text class="five-level-col-title">成交量</text>
        <text class="five-level-col-title">折溢价率</text>
      </view>
      <view class="five-level-row" wx:for="{{fiveLevel.bid}}" wx:key="index">
        <text class="five-level-price bid">{{item.price}}</text>
        <text class="five-level-vol">{{item.volume}}</text>
        <text class="five-level-premium down">{{item.premium}}</text>
      </view>
    </view>
  </view>

  <!-- 基金统计数据 -->
  <view class="stats-card">
    <view class="stats-title">套利数据统计</view>
    <!-- 条件1 -->
    <view class="stats-item">
      <view class="stats-condition">
        <text class="stats-threshold">溢价率{{fundStats.threshold1.minPremium}}({{fundStats.threshold1.position}})</text>
        <text class="stats-since">始于: {{fundStats.threshold1.startDate}}</text>
      </view>
      <view class="stats-grid">
        <view class="stats-cell">
          <text class="stats-cell-value">{{fundStats.threshold1.count}}</text>
          <text class="stats-cell-label">套利出现次数</text>
        </view>
        <view class="stats-cell">
          <text class="stats-cell-value green">{{fundStats.threshold1.successRate}}</text>
          <text class="stats-cell-label">套利总成功率</text>
        </view>
        <view class="stats-cell">
          <text class="stats-cell-value green">{{fundStats.threshold1.totalProfit}}</text>
          <text class="stats-cell-label">套利总收益率</text>
        </view>
        <view class="stats-cell">
          <text class="stats-cell-value">{{fundStats.threshold1.prob}}</text>
          <text class="stats-cell-label">套利出现概率</text>
        </view>
      </view>
    </view>
    <!-- 条件2 -->
    <view class="stats-item">
      <view class="stats-condition">
        <text class="stats-threshold">溢价率{{fundStats.threshold2.minPremium}}({{fundStats.threshold2.position}})</text>
        <view class="stats-starred-tag">
          <text class="star-icon">★</text>
          <text>加入自选</text>
        </view>
      </view>
      <view class="stats-grid">
        <view class="stats-cell">
          <text class="stats-cell-value">{{fundStats.threshold2.count}}</text>
          <text class="stats-cell-label">套利出现次数</text>
        </view>
        <view class="stats-cell">
          <text class="stats-cell-value green">{{fundStats.threshold2.successRate}}</text>
          <text class="stats-cell-label">套利总成功率</text>
        </view>
        <view class="stats-cell">
          <text class="stats-cell-value green">{{fundStats.threshold2.totalProfit}}</text>
          <text class="stats-cell-label">套利总收益率</text>
        </view>
        <view class="stats-cell">
          <text class="stats-cell-value">{{fundStats.threshold2.prob}}</text>
          <text class="stats-cell-label">套利出现概率</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 历史净值表格 -->
  <view class="nav-card">
    <view class="nav-header">
      <text class="nav-title">历史净值</text>
    </view>
    <view class="nav-table">
      <!-- 表头 -->
      <view class="nav-thead">
        <text class="nav-th nav-th-date">日期</text>
        <text class="nav-th">净值</text>
        <text class="nav-th">A股收盘</text>
        <text class="nav-th">溢价率</text>
        <text class="nav-th">净值误差率</text>
        <text class="nav-th">万份</text>
      </view>
      <!-- 数据行 -->
      <view class="nav-tbody">
        <view class="nav-tr" wx:for="{{navHistory}}" wx:key="date">
          <text class="nav-td nav-td-date">{{item.date}}</text>
          <view class="nav-td nav-td-nav">
            <text class="nav-value">{{item.nav}}</text>
            <text class="nav-change {{item.navChange.startsWith('-') ? 'down' : 'up'}}">{{item.navChange}}</text>
          </view>
          <text class="nav-td {{item.aShareClose.startsWith('-') ? 'down' : 'up'}}">{{item.aShareClose}}</text>
          <text class="nav-td {{item.premium.startsWith('-') ? 'down' : 'up'}}">{{item.premium}}</text>
          <text class="nav-td {{item.errorRate.startsWith('-') ? 'down' : 'up'}}">{{item.errorRate}}</text>
          <text class="nav-td">{{item.profit}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 不拖说明卡片 -->
  <view class="info-card">
    <view class="info-card-header">
      <text class="info-card-icon">⚠️</text>
      <text class="info-card-title">重要提示</text>
    </view>
    <view class="info-card-item">不拖: 不能使用拖拉机，按身份证限额。</view>
    <view class="info-card-item">场外: 只能场外申购转场内吃溢价。</view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-section">
    <view class="action-btn" bindtap="onCopyCode">
      <text class="btn-icon">📋</text>
      <text class="btn-text">复制基金代码</text>
    </view>
    <view class="action-btn" bindtap="onCopyName">
      <text class="btn-icon">📝</text>
      <text class="btn-text">复制基金名称</text>
    </view>
  </view>

  <!-- 免责声明 -->
  <view class="disclaimer">
    <text class="disclaimer-text">数据仅供参考，不构成任何投资建议。</text>
    <text class="disclaimer-text">数据有一定的延时，仅供参考，请确认顶部更新时间。</text>
  </view>

  <!-- 最强攻略 -->
  <view class="guide-card">
    <view class="guide-header">
      <text class="guide-icon">📚</text>
      <text class="guide-title">最强攻略文章，没看就别说自己不会!</text>
    </view>
    <view class="guide-item">
      <text class="guide-arrow">▶</text>
      <text class="guide-content">最强基金干货，直接解决你99%的疑惑</text>
    </view>
    <view class="guide-item">
      <text class="guide-arrow">▶</text>
      <text class="guide-content">场外基金怎么转入场内吃溢价，最详实操教程</text>
    </view>
  </view>
</view>
