.page {
  min-height: 100vh;
  background: #f5f7fa;
  box-sizing: border-box;
}

.content {
  height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  overflow: hidden;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  margin-right: 20rpx;
  line-height: 1.5;
}

.switch-control {
  flex-shrink: 0;
}

switch {
  position: relative;
  z-index: 2;
}

/* 子选项区域 */
.sub-items {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.sub-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}

.sub-item:last-child {
  padding-bottom: 0;
}

.sub-label {
  font-size: 28rpx;
  color: #666;
}

/* 阈值设置区域 */
.threshold-section {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.threshold-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.threshold-row:last-child {
  margin-bottom: 0;
}

.threshold-label {
  font-size: 26rpx;
  color: #666;
  min-width: 200rpx;
  flex-shrink: 0;
}

.threshold-input {
  flex: 1;
  height: 70rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #333;
  box-sizing: border-box;
}

.threshold-input::placeholder {
  color: #999;
}

/* 保存按钮区域 */
.save-btn-row {
  margin-top: 30rpx;
  display: flex;
  justify-content: center;
}

.save-btn {
  width: 200rpx;
  height: 70rpx;
  line-height: 70rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 28rpx;
  border-radius: 35rpx;
  border: none;
  padding: 0;
  margin: 0;
}

.save-btn::after {
  border: none;
}
