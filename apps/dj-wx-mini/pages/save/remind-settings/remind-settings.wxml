<view class="page">
  <scroll-view scroll-y class="content">
    <!-- 基金套利提醒阈值 -->
    <view class="card">
      <view class="card-header">
        <text class="card-title">1. 基金套利提醒阈值</text>
        <view class="switch-control">
          <switch checked="{{fundArbitrageEnabled}}" color="#667eea" bindchange="onFundArbitrageToggle" />
        </view>
      </view>
      <view wx:if="{{fundArbitrageEnabled}}" class="sub-items">
        <view class="sub-item">
          <text class="sub-label">股票LOF</text>
          <switch checked="{{stockLOFEnabled}}" color="#667eea" bindchange="onStockLOFToggle" />
        </view>
        <view class="sub-item">
          <text class="sub-label">指数LOF</text>
          <switch checked="{{indexLOFEnabled}}" color="#667eea" bindchange="onIndexLOFToggle" />
        </view>
        <view class="sub-item">
          <text class="sub-label">其它LOF</text>
          <switch checked="{{otherLOFEnabled}}" color="#667eea" bindchange="onOtherLOFToggle" />
        </view>
      </view>

      <!-- 阈值设置 -->
      <view wx:if="{{fundArbitrageEnabled}}" class="threshold-section">
        <view class="threshold-row">
          <text class="threshold-label">溢价(正数)&gt;</text>
          <input class="threshold-input" type="digit" value="{{premiumThreshold}}" bindinput="onPremiumThresholdInput" placeholder="默认: 0.5" />
        </view>
        <view class="threshold-row">
          <text class="threshold-label">折价(负数)&lt;</text>
          <input class="threshold-input" type="digit" value="{{discountThreshold}}" bindinput="onDiscountThresholdInput" placeholder="默认: -1" />
        </view>
        <view class="threshold-row">
          <text class="threshold-label">成交额(万)&gt;</text>
          <input class="threshold-input" type="digit" value="{{turnoverThreshold}}" bindinput="onTurnoverThresholdInput" placeholder="默认: 100" />
        </view>
      </view>
    </view>

    <!-- 盘中高溢价套利机会提醒 -->
    <view class="card">
      <view class="card-header">
        <text class="card-title">2. 盘中(实时)监控高溢价套利机会提醒(自选)</text>
        <view class="switch-control">
          <switch checked="{{realtimePremiumEnabled}}" color="#667eea" bindchange="onRealtimePremiumToggle" />
        </view>
      </view>
      <view wx:if="{{realtimePremiumEnabled}}" class="threshold-section">
        <view class="threshold-row">
          <text class="threshold-label">买1金额(元)&gt;</text>
          <input class="threshold-input" type="digit" value="{{buy1AmountThreshold}}" bindinput="onBuy1AmountInput" placeholder="默认: 5000" />
        </view>
        <view class="threshold-row">
          <text class="threshold-label">溢价率&gt;</text>
          <input class="threshold-input" type="digit" value="{{realtimePremiumThreshold}}" bindinput="onRealtimePremiumInput" placeholder="默认: 1.88" />
        </view>
        <view class="save-btn-row">
          <button class="save-btn" bindtap="saveRealtimePremiumSettings">保存设置</button>
        </view>
      </view>
    </view>

    <!-- 封闭基金折价提醒 -->
    <view class="card">
      <view class="card-header">
        <text class="card-title">3. 封闭基金折价大于5%提醒(关注的)</text>
        <view class="switch-control">
          <switch checked="{{closedFundDiscountEnabled}}" color="#667eea" bindchange="onClosedFundDiscountToggle" />
        </view>
      </view>
    </view>

    <!-- 可转债申购提醒 -->
    <view class="card">
      <view class="card-header">
        <text class="card-title">4. 早上可转债申购提醒</text>
        <view class="switch-control">
          <switch checked="{{morningSubscribeEnabled}}" color="#667eea" bindchange="onMorningSubscribeToggle" />
        </view>
      </view>
    </view>

    <!-- 14点可转债申购再次提醒 -->
    <view class="card">
      <view class="card-header">
        <text class="card-title">5. 14点可转债申购再次提醒</text>
        <view class="switch-control">
          <switch checked="{{afternoonSubscribeEnabled}}" color="#667eea" bindchange="onAfternoonSubscribeToggle" />
        </view>
      </view>
    </view>

    <!-- 可转债上市提醒 -->
    <view class="card">
      <view class="card-header">
        <text class="card-title">6. 可转债上市提醒</text>
        <view class="switch-control">
          <switch checked="{{convertibleBondListEnabled}}" color="#667eea" bindchange="onConvertibleBondListToggle" />
        </view>
      </view>
    </view>

    <!-- 可转债强赎公告结果提醒 -->
    <view class="card">
      <view class="card-header">
        <text class="card-title">7. 可转债强赎公告结果提醒</text>
        <view class="switch-control">
          <switch checked="{{convertibleBondRedeemEnabled}}" color="#667eea" bindchange="onConvertibleBondRedeemToggle" />
        </view>
      </view>
    </view>

    <!-- 可转债预计触发强赎提醒 -->
    <view class="card">
      <view class="card-header">
        <text class="card-title">8. 可转债预计触发强赎提醒(满足天数≥10)</text>
        <view class="switch-control">
          <switch checked="{{convertibleBondExpectedRedeemEnabled}}" color="#667eea" bindchange="onConvertibleBondExpectedRedeemToggle" />
        </view>
      </view>
    </view>

    <!-- 可转债公告下修提醒 -->
    <view class="card">
      <view class="card-header">
        <text class="card-title">9. 可转债公告下修提醒</text>
        <view class="switch-control">
          <switch checked="{{convertibleBondLowerEnabled}}" color="#667eea" bindchange="onConvertibleBondLowerToggle" />
        </view>
      </view>
    </view>

    <!-- 可转债涨幅落后正股提醒 -->
    <view class="card">
      <view class="card-header">
        <text class="card-title">10. 可转债涨幅落后正股提醒(慎开)</text>
        <view class="switch-control">
          <switch checked="{{convertibleBondLagEnabled}}" color="#667eea" bindchange="onConvertibleBondLagToggle" />
        </view>
      </view>
      <view wx:if="{{convertibleBondLagEnabled}}" class="threshold-section">
        <view class="threshold-row">
          <text class="threshold-label">可转债价格要求&lt;</text>
          <input class="threshold-input" type="digit" value="{{bondPriceThreshold}}" bindinput="onBondPriceInput" placeholder="最高价格" />
        </view>
        <view class="threshold-row">
          <text class="threshold-label">可转债溢价率要求&lt;</text>
          <input class="threshold-input" type="digit" value="{{bondPremiumThreshold}}" bindinput="onBondPremiumInput" placeholder="最高溢价率" />
        </view>
        <view class="save-btn-row">
          <button class="save-btn" bindtap="saveConvertibleBondLagSettings">保存设置</button>
        </view>
      </view>
    </view>

    <!-- 可转债中位数提醒 -->
    <view class="card">
      <view class="card-header">
        <text class="card-title">11. 可转债中位数提醒</text>
        <view class="switch-control">
          <switch checked="{{convertibleBondMedianEnabled}}" color="#667eea" bindchange="onConvertibleBondMedianToggle" />
        </view>
      </view>
    </view>
  </scroll-view>
</view>
