.page {
  min-height: 100vh;
  background: #f5f9ff;
  color: #20304a;
}

.hero {
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 26rpx 24rpx 22rpx;
  background: #ffffff;
}

.hero-center {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.hero-label {
  font-size: 26rpx;
  color: #1f2937;
  font-weight: 600;
}

.hero-time {
  font-size: 26rpx;
  color: #ff6a00;
  font-weight: 700;
}

.hero-brand {
  position: absolute;
  right: 18rpx;
  top: 22rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.hero-brand-icon {
  font-size: 34rpx;
}

.hero-brand-text {
  font-size: 22rpx;
  color: #ff6a00;
  font-weight: 700;
}

.table-header {
  display: flex;
  padding: 16rpx 10rpx 18rpx;
  background: #ffffff;
  border-top: 1rpx solid #eef3fb;
  border-bottom: 1rpx solid #eef3fb;
}

.header-cell,
.row-cell {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.name-cell {
  width: 230rpx;
  padding-left: 6rpx;
}

.metric-cell {
  width: 130rpx;
}

.spread-cell {
  width: 148rpx;
}

.discount-cell {
  width: 144rpx;
}

.action-cell {
  width: 110rpx;
  align-items: flex-end;
  padding-right: 6rpx;
}

.header-title,
.header-subtitle,
.header-link {
  font-size: 22rpx;
  line-height: 1.65;
}

.header-title,
.header-subtitle {
  color: #1f2937;
}

.header-link {
  color: #3b82f6;
}

.header-link.dark {
  color: #1f2937;
}

.table-body {
  height: calc(100vh - 160rpx);
  background: #ffffff;
}

.table-row {
  display: flex;
  min-height: 138rpx;
  padding: 18rpx 10rpx;
  align-items: center;
}

.table-row.alt {
  background: #edf5ff;
}

.fund-name {
  font-size: 28rpx;
  color: #2e6fd8;
  line-height: 1.5;
}

.fund-code {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #2e6fd8;
  line-height: 1.4;
}

.metric-main {
  font-size: 25rpx;
  color: #1f2937;
  line-height: 1.6;
}

.metric-accent,
.metric-sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #1f2937;
  line-height: 1.4;
}

.metric-accent.up {
  color: #ff3b30;
}

.metric-sub.down {
  color: #1f2937;
}

.follow-switch {
  position: relative;
  width: 76rpx;
  height: 40rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 2rpx solid #d9e2f2;
  box-shadow: inset 0 2rpx 4rpx rgba(31, 41, 55, 0.08);
}

.follow-switch-thumb {
  position: absolute;
  left: 2rpx;
  top: 2rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #ffffff 0%, #e8eff9 100%);
  box-shadow: 0 2rpx 6rpx rgba(31, 41, 55, 0.12);
}

.follow-switch.active {
  background: #ffefe4;
  border-color: #ff9b5e;
}

.follow-switch.active .follow-switch-thumb {
  left: 38rpx;
  background: linear-gradient(180deg, #ffb070 0%, #ff8c43 100%);
}

.remaining-badge {
  margin-top: 20rpx;
  min-width: 74rpx;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  background: #ff9257;
  font-size: 22rpx;
  line-height: 1.3;
  color: #ffffff;
  text-align: center;
}
