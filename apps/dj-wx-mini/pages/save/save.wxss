.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 0 0 120rpx 0;
  box-sizing: border-box;
}

/* 顶部卡片 */
.top-card {
  background: linear-gradient(135deg, #667eea, #764ba2);
  padding: 24rpx 30rpx;
}

.top-header {
  margin-bottom: 0;
}

.top-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.top-subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 6rpx;
  display: block;
}

/* 内容区域 */
.content {
  padding: 24rpx;
  height: calc(100vh - 180rpx);
  box-sizing: border-box;
}

/* 分区 */
.section {
  margin-bottom: 30rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
}

.section-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
  display: block;
}

/* 工具网格 */
.tools-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.tool-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.tool-icon-bg {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 14rpx;
}

.tool-icon-bg.orange { background: linear-gradient(135deg, #ffa726, #ff9800); }
.tool-icon-bg.red { background: linear-gradient(135deg, #ef5350, #e53935); }
.tool-icon-bg.blue { background: linear-gradient(135deg, #42a5f5, #1e88e5); }
.tool-icon-bg.green { background: linear-gradient(135deg, #66bb6a, #43a047); }
.tool-icon-bg.purple { background: linear-gradient(135deg, #ab47bc, #8e24aa); }
.tool-icon-bg.pink { background: linear-gradient(135deg, #f06292, #ec407a); }
.tool-icon-bg.cyan { background: linear-gradient(135deg, #26c6da, #00acc1); }
.tool-icon-bg.indigo { background: linear-gradient(135deg, #5c6bc0, #3949ab); }
.tool-icon-bg.teal { background: linear-gradient(135deg, #26a69a, #00897b); }

.tool-icon {
  font-size: 40rpx;
}

.tool-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
}

.tool-desc {
  font-size: 20rpx;
  color: #999;
  display: block;
  line-height: 1.4;
}
