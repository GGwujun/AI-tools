<view class="page">
  <!-- 顶部卡片 -->
  <view class="top-card">
    <view class="top-header">
      <text class="top-title">💰 储钱助手</text>
      <text class="top-subtitle">让你的钱袋子越来越鼓</text>
    </view>
  </view>

  <scroll-view scroll-y class="content">
    <!-- 基金神器 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">📊 基金神器</text>
        <text class="section-desc">专注基金投资，智能辅助决策</text>
      </view>
      <view class="tools-grid">
        <view class="tool-card" wx:for="{{fundTools}}" wx:key="id" bindtap="goToTool" data-id="{{item.id}}" data-name="{{item.name}}">
          <view class="tool-icon-bg {{item.color}}">
            <text class="tool-icon">{{item.icon}}</text>
          </view>
          <text class="tool-name">{{item.name}}</text>
          <text class="tool-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>

    <!-- 转债神器 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">📈 转债神器</text>
        <text class="section-desc">可转债投资必备工具箱</text>
      </view>
      <view class="tools-grid">
        <view class="tool-card" wx:for="{{bondTools}}" wx:key="id" bindtap="goToTool" data-id="{{item.id}}" data-name="{{item.name}}">
          <view class="tool-icon-bg {{item.color}}">
            <text class="tool-icon">{{item.icon}}</text>
          </view>
          <text class="tool-name">{{item.name}}</text>
          <text class="tool-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>

    <!-- 超级福利 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">🎁 超级福利</text>
        <text class="section-desc">薅羊毛 & 互助社区</text>
      </view>
      <view class="tools-grid">
        <view class="tool-card" wx:for="{{welfareTools}}" wx:key="id" bindtap="goToTool" data-id="{{item.id}}" data-name="{{item.name}}">
          <view class="tool-icon-bg {{item.color}}">
            <text class="tool-icon">{{item.icon}}</text>
          </view>
          <text class="tool-name">{{item.name}}</text>
          <text class="tool-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
