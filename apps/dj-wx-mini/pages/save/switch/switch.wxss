.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 0 0 120rpx 0;
  box-sizing: border-box;
  padding-right: 24rpx;
}

.content {
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  overflow: hidden;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 0;
  position: relative;
  z-index: 1;
}

.switch-row.master {
  padding: 0;
  position: relative;
  z-index: 1;
}

.switch-info {
  flex: 1;
  margin-right: 20rpx;
  position: relative;
  z-index: 1;
}

.switch-control {
  position: relative;
  z-index: 2;
  flex-shrink: 0;
}

switch {
  position: relative;
  z-index: 2;
}

.switch-label {
  font-size: 30rpx;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
}

.switch-status {
  font-size: 24rpx;
  display: block;
}

.switch-status.on {
  color: #52c41a;
}

.switch-status.off {
  color: #999;
}

.switch-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 20rpx 0;
}

.threshold-header {
  margin-bottom: 24rpx;
}

.threshold-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.threshold-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.threshold-options {
  display: flex;
  gap: 16rpx;
}

.threshold-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
}

.threshold-btn.active {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-weight: 600;
}

/* 更多提醒设置卡片 */
.more-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  cursor: pointer;
}

.more-info {
  flex: 1;
}

.more-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
}

.more-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.more-arrow {
  font-size: 44rpx;
  color: #ccc;
  flex-shrink: 0;
  margin-left: 16rpx;
}
