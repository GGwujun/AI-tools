<view class="page">
  <view class="content">
    <!-- 提醒总开关 -->
    <view class="card">
      <view class="switch-row master">
        <view class="switch-info" bindtap="onMasterToggle">
          <text class="switch-label">提醒总开关</text>
          <text class="switch-status {{masterEnabled ? 'on' : 'off'}}">{{masterEnabled ? '已开启提醒，当日涨跌幅超过阈值时推送提醒' : '已关闭提醒'}}</text>
        </view>
        <view class="switch-control">
          <switch checked="{{masterEnabled}}" color="#667eea" bindchange="onMasterToggle" />
        </view>
      </view>
    </view>

    <!-- 三类提醒 -->
    <view class="card">
      <view class="switch-row">
        <view class="switch-info" bindtap="onMarketToggle">
          <text class="switch-label">📊 大盘异动提醒</text>
          <text class="switch-desc">监测沪深300、创业板等指数涨跌</text>
        </view>
        <view class="switch-control">
          <switch checked="{{marketEnabled}}" color="#667eea" bindchange="onMarketToggle" />
        </view>
      </view>

      <view class="divider"></view>

      <view class="switch-row">
        <view class="switch-info" bindtap="onFollowedToggle">
          <text class="switch-label">⭐ 关注基金提醒</text>
          <text class="switch-desc">您关注的基金涨跌时推送通知</text>
        </view>
        <view class="switch-control">
          <switch checked="{{followedEnabled}}" color="#667eea" bindchange="onFollowedToggle" />
        </view>
      </view>

      <view class="divider"></view>

      <view class="switch-row">
        <view class="switch-info" bindtap="onOptionalToggle">
          <text class="switch-label">💼 我的自选提醒</text>
          <text class="switch-desc">自选基金涨跌时及时知晓</text>
        </view>
        <view class="switch-control">
          <switch checked="{{optionalEnabled}}" color="#667eea" bindchange="onOptionalToggle" />
        </view>
      </view>
    </view>

    <!-- 涨跌幅阈值 -->
    <view class="card">
      <view class="threshold-header">
        <text class="threshold-title">📊 涨跌幅阈值设置</text>
        <text class="threshold-desc">当日涨跌幅超过 N% 时触发提醒</text>
      </view>
      <view class="threshold-options">
        <view class="threshold-btn {{threshold == 2 ? 'active' : ''}}" bindtap="onThresholdSelect" data-value="2">2%</view>
        <view class="threshold-btn {{threshold == 3 ? 'active' : ''}}" bindtap="onThresholdSelect" data-value="3">3%</view>
        <view class="threshold-btn {{threshold == 5 ? 'active' : ''}}" bindtap="onThresholdSelect" data-value="5">5%</view>
        <view class="threshold-btn {{threshold == 8 ? 'active' : ''}}" bindtap="onThresholdSelect" data-value="8">8%</view>
      </view>
    </view>

    <!-- 更多提醒设置 -->
    <view class="card more-card" bindtap="goToRemindSettings">
      <view class="more-info">
        <text class="more-title">🔔 更多提醒设置</text>
        <text class="more-desc">基金套利、可转债等高级提醒功能</text>
      </view>
      <text class="more-arrow">›</text>
    </view>
  </view>
</view>
