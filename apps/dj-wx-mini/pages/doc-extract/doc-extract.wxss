.page { min-height:100vh; background:#f7f8fa; }
.scroll { height:100vh; padding:20rpx 24rpx 32rpx; box-sizing:border-box; }
.hero-card,.section-card { border-radius:28rpx; background:#fff; box-shadow:0 12rpx 32rpx rgba(16,24,40,0.06); }
.hero-card { padding:28rpx 24rpx; }
.hero-title { display:block; color:#101828; font-size:34rpx; font-weight:700; }
.hero-desc { display:block; margin-top:14rpx; color:#667085; font-size:24rpx; }
.section-card { margin-top:18rpx; padding:24rpx; }
.section-head { display:flex; align-items:center; justify-content:space-between; gap:12rpx; }
.section-title { color:#101828; font-size:28rpx; font-weight:700; }
.section-body { display:block; margin-top:16rpx; color:#475467; font-size:24rpx; line-height:1.9; }
.copy-btn { min-width:140rpx; height:60rpx; padding:0 18rpx; border-radius:16rpx; background:#eef4ff; color:#1565ff; font-size:22rpx; font-weight:600; display:flex; align-items:center; justify-content:center; }
.copy-btn::after { border:none; }
