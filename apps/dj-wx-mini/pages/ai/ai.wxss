.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 0 0 120rpx 0;
  box-sizing: border-box;
}

.header {
  background: linear-gradient(135deg, #667eea, #764ba2);
  padding: 60rpx 30rpx;
  text-align: center;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.header-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 12rpx;
  display: block;
}

.content {
  padding: 24rpx 24rpx 24rpx 24rpx;
  height: calc(100vh - 200rpx);
  box-sizing: border-box;
}

/* 功能列表 */
.tools-list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  margin-bottom: 30rpx;
}

.tool-card {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.tool-card:last-child {
  border-bottom: none;
}

.tool-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.tool-icon text {
  font-size: 44rpx;
}

.tool-icon.purple {
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.tool-icon.pink {
  background: linear-gradient(135deg, #f093fb, #f5576c);
}

.tool-icon.blue {
  background: linear-gradient(135deg, #4facfe, #00f2fe);
}

.tool-icon.green {
  background: linear-gradient(135deg, #43e97b, #38f9d7);
}

.tool-icon.red {
  background: linear-gradient(135deg, #ff6b6b, #ee5a24);
}

.tool-info {
  flex: 1;
}

.tool-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
}

.tool-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.tool-arrow {
  font-size: 44rpx;
  color: #ccc;
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* 统计卡片 */
.stats-card {
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(102, 126, 234, 0.3);
}

.stats-title {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
  display: block;
  margin-bottom: 24rpx;
}

.stats-grid {
  display: flex;
  justify-content: space-between;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 6rpx;
  display: block;
}

/* 提示区域 */
.tips-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.tips-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.tip-item {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  display: block;
  margin-bottom: 12rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}
