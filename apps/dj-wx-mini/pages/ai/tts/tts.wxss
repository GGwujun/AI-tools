.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 120rpx;
  box-sizing: border-box;
}

.content {
  padding: 24rpx 24rpx 24rpx 24rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
}

.card-header .card-title {
  margin-bottom: 0;
}

.char-count {
  font-size: 24rpx;
  color: #999;
}

.textarea {
  width: 100%;
  min-height: 200rpx;
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

/* 音色选择 */
.voice-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.voice-item {
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  border: 4rpx solid transparent;
  transition: all 0.3s;
}

.voice-item.active {
  background: rgba(67, 233, 123, 0.1);
  border-color: #43e97b;
}

.voice-item.active .voice-name {
  color: #43e97b;
}

.voice-icon {
  font-size: 36rpx;
  display: block;
  margin-bottom: 8rpx;
}

.voice-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 4rpx;
}

.voice-desc {
  font-size: 22rpx;
  color: #888;
  display: block;
}

/* 参数设置 */
.setting-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.setting-item:last-child {
  margin-bottom: 0;
}

.setting-label {
  font-size: 28rpx;
  color: #666;
  width: 80rpx;
  flex-shrink: 0;
}

.setting-slider {
  flex: 1;
}

/* 生成按钮 */
.generate-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #43e97b, #38f9d7);
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 50rpx;
  border: none;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 30rpx rgba(67, 233, 123, 0.4);
}

.generate-btn.loading {
  opacity: 0.7;
}

/* 预览 */
.preview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.duration {
  font-size: 24rpx;
  color: #999;
}

.audio-player {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
}

.play-btn {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #43e97b, #38f9d7);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.play-btn text {
  font-size: 36rpx;
  color: #fff;
}

.progress-bar {
  flex: 1;
}

.progress-bg {
  height: 8rpx;
  background: #ddd;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #43e97b, #38f9d7);
  border-radius: 4rpx;
}

.time-label {
  font-size: 22rpx;
  color: #999;
  flex-shrink: 0;
  min-width: 80rpx;
  text-align: right;
}

.play-hint {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-top: 16rpx;
  display: block;
}

.audio-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.save-btn,
.share-btn {
  flex: 1;
  height: 88rpx;
  font-size: 30rpx;
  border-radius: 44rpx;
  border: none;
}

.save-btn {
  background: linear-gradient(135deg, #43e97b, #38f9d7);
  color: #fff;
}

.share-btn {
  background: #fff;
  color: #43e97b;
  border: 2rpx solid #43e97b;
}

/* 场景 */
.scene-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.scene-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
}

.scene-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.scene-name {
  font-size: 24rpx;
  color: #666;
}
