.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(14, 165, 233, 0.08), transparent 26%),
    radial-gradient(circle at top left, rgba(15, 118, 110, 0.14), transparent 32%),
    #f3ede1;
}

.scroll {
  height: 100vh;
  padding: 24rpx 24rpx 150rpx;
  box-sizing: border-box;
}

.hero-shell {
  position: relative;
}

.hero-glow {
  position: absolute;
  border-radius: 999rpx;
  filter: blur(10rpx);
}

.hero-glow-one {
  width: 220rpx;
  height: 220rpx;
  top: 20rpx;
  right: 10rpx;
  background: rgba(249, 115, 22, 0.12);
}

.hero-glow-two {
  width: 170rpx;
  height: 170rpx;
  left: 16rpx;
  bottom: 30rpx;
  background: rgba(45, 212, 191, 0.08);
}

.hero {
  position: relative;
  padding: 34rpx;
  border-radius: 34rpx;
  background: linear-gradient(145deg, #101827, #0f766e 70%, #8b4513);
  box-shadow: 0 20rpx 42rpx rgba(15, 118, 110, 0.16);
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.hero-badge,
.hero-state {
  display: inline-flex;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  color: #fff;
  font-size: 22rpx;
}

.hero-state.running {
  background: rgba(14, 165, 233, 0.18);
}

.hero-state.success {
  background: rgba(34, 197, 94, 0.16);
}

.hero-state.failed {
  background: rgba(239, 68, 68, 0.18);
}

.hero-title {
  display: block;
  margin-top: 22rpx;
  color: #fff;
  font-size: 46rpx;
  font-weight: 700;
}

.hero-desc {
  display: block;
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.84);
  font-size: 24rpx;
  line-height: 1.7;
}

.notice-card,
.card,
.analysis-item,
.mode-item,
.platform-card {
  border-radius: 28rpx;
}

.notice-card,
.card {
  margin-top: 24rpx;
  padding: 28rpx;
  background: rgba(255, 252, 246, 0.94);
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.06);
}

.notice-card {
  background: #fff7ed;
  border: 2rpx solid rgba(180, 83, 9, 0.12);
}

.notice-title,
.card-title {
  display: block;
  color: #111827;
  font-size: 30rpx;
  font-weight: 700;
}

.card-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 20rpx;
}

.card-subtitle {
  color: #6b7280;
  font-size: 22rpx;
  text-align: right;
}

.notice-item {
  display: block;
  margin-top: 12rpx;
  color: #9a3412;
  font-size: 24rpx;
  line-height: 1.6;
}

.input-box {
  margin-top: 18rpx;
  width: 100%;
  min-height: 220rpx;
  border-radius: 24rpx;
  padding: 24rpx;
  box-sizing: border-box;
  background: #f8fafc;
  color: #111827;
  font-size: 28rpx;
  line-height: 1.65;
}

.smart-hint {
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(160deg, #ecfeff, #fffdf8);
}

.smart-hint-label {
  display: block;
  color: #0f766e;
  font-size: 22rpx;
  font-weight: 600;
}

.smart-hint-text {
  display: block;
  margin-top: 8rpx;
  color: #134e4a;
  font-size: 24rpx;
  line-height: 1.6;
}

.analysis-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 18rpx;
}

.analysis-item {
  padding: 18rpx;
  background: #f8fafc;
}

.analysis-label {
  display: block;
  color: #6b7280;
  font-size: 20rpx;
}

.analysis-value {
  display: block;
  margin-top: 8rpx;
  color: #111827;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.5;
}

.signal-board {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: #f8fafc;
}

.signal-row {
  padding: 16rpx 18rpx;
  border-radius: 20rpx;
  background: #fff;
}

.signal-label {
  display: block;
  color: #6b7280;
  font-size: 20rpx;
}

.signal-value {
  display: block;
  margin-top: 8rpx;
  color: #111827;
  font-size: 26rpx;
  font-weight: 600;
}

.select-section {
  margin-top: 20rpx;
}

.clean-card {
  margin-top: 16rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: #f8fafc;
}

.clean-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.clean-title {
  color: #111827;
  font-size: 24rpx;
  font-weight: 700;
}

.clean-meta {
  color: #6b7280;
  font-size: 20rpx;
  text-align: right;
}

.platform-summary {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.platform-summary-item {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #ecfeff;
  color: #0f766e;
  font-size: 20rpx;
}

.clean-link-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 14rpx;
}

.clean-link-item {
  padding: 16rpx 18rpx;
  border-radius: 20rpx;
  background: #fff;
}

.clean-link-item.active {
  background: #ecfeff;
}

.clean-link-platform {
  display: block;
  color: #0f766e;
  font-size: 20rpx;
  font-weight: 600;
}

.clean-link-url {
  display: block;
  margin-top: 6rpx;
  color: #4b5563;
  font-size: 22rpx;
  line-height: 1.5;
  word-break: break-all;
}

.clean-actions {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 14rpx;
}

.clean-action {
  color: #0f766e;
  font-size: 22rpx;
}

.sub-title {
  display: block;
  color: #374151;
  font-size: 24rpx;
  font-weight: 600;
}

.chip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 14rpx;
}

.chip {
  min-width: 110rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #e0f2fe;
  color: #075985;
  font-size: 24rpx;
  text-align: center;
  box-sizing: border-box;
}

.chip.active {
  background: #0f766e;
  color: #fff;
}

.chip.passive {
  background: #ecfeff;
  color: #0f766e;
}

.route-recommend-card {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: linear-gradient(160deg, #ecfeff, #fffdf8);
}

.route-recommend-text {
  display: block;
  color: #0f766e;
  font-size: 22rpx;
  line-height: 1.6;
}

.route-score-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 16rpx;
}

.route-score-item {
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: #f8fafc;
}

.route-score-item.selected {
  background: #ecfeff;
}

.route-score-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.route-score-name {
  color: #111827;
  font-size: 24rpx;
  font-weight: 600;
}

.route-score-badge {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #e2e8f0;
  color: #475569;
  font-size: 20rpx;
}

.route-score-badge.recommended {
  background: #0f766e;
  color: #fff;
}

.route-score-note {
  display: block;
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.5;
}

.button-stack {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 22rpx;
}

.primary-btn,
.secondary-btn,
.batch-btn,
.retry-btn,
.task-link-btn {
  height: 88rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
}

.primary-btn,
.retry-btn {
  background: #0f766e;
  color: #fff;
}

.secondary-btn {
  background: #fff7ed;
  color: #b45309;
  border: 2rpx solid rgba(180, 83, 9, 0.18);
}

.batch-btn {
  background: #ecfeff;
  color: #0f766e;
  border: 2rpx solid rgba(15, 118, 110, 0.18);
}

.task-link-btn {
  margin-top: 18rpx;
  background: #f8fafc;
  color: #0f766e;
  border: 2rpx solid rgba(15, 118, 110, 0.12);
}

.primary-btn::after,
.secondary-btn::after,
.batch-btn::after,
.retry-btn::after,
.task-link-btn::after {
  border: none;
}

.inline-actions {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
}

.inline-action {
  color: #0f766e;
  font-size: 24rpx;
}

.status-pill {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: #f1f5f9;
  color: #475569;
}

.status-pill.running {
  background: #e0f2fe;
  color: #075985;
}

.status-pill.success {
  background: #dcfce7;
  color: #166534;
}

.status-pill.failed {
  background: #fee2e2;
  color: #b91c1c;
}

.status-desc {
  display: block;
  margin-top: 14rpx;
  color: #4b5563;
  font-size: 24rpx;
  line-height: 1.6;
}

.batch-panel,
.route-panel {
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: #f8fafc;
}

.batch-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.batch-title,
.route-title {
  display: block;
  color: #111827;
  font-size: 24rpx;
  font-weight: 700;
}

.batch-current {
  color: #6b7280;
  font-size: 22rpx;
  text-align: right;
}

.batch-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  margin-top: 16rpx;
}

.batch-item {
  padding: 18rpx;
  border-radius: 20rpx;
  background: #fff;
}

.batch-item.success {
  background: linear-gradient(160deg, #ecfdf5, #fff);
}

.batch-item.failed {
  background: linear-gradient(160deg, #fef2f2, #fff);
}

.batch-label {
  display: block;
  color: #6b7280;
  font-size: 20rpx;
}

.batch-value {
  display: block;
  margin-top: 8rpx;
  color: #111827;
  font-size: 28rpx;
  font-weight: 700;
}

.timeline {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.timeline-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.timeline-node {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #cbd5e1;
}

.timeline-node.running {
  background: #0ea5e9;
}

.timeline-node.done {
  background: #10b981;
}

.timeline-node.failed {
  background: #ef4444;
}

.timeline-title {
  color: #111827;
  font-size: 24rpx;
  font-weight: 600;
}

.route-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 16rpx;
}

.route-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: #fff;
}

.route-item.running {
  background: linear-gradient(160deg, #eff6ff, #fff);
}

.route-item.success {
  background: linear-gradient(160deg, #ecfdf5, #fff);
}

.route-item.failed {
  background: linear-gradient(160deg, #fef2f2, #fff);
}

.route-body {
  flex: 1;
  min-width: 0;
}

.route-name {
  display: block;
  color: #111827;
  font-size: 24rpx;
  font-weight: 600;
}

.route-detail {
  display: block;
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.5;
}

.route-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.route-order,
.route-status {
  font-size: 20rpx;
  color: #6b7280;
}

.failure-box {
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: #fff7ed;
}

.failure-title {
  display: block;
  color: #9a3412;
  font-size: 24rpx;
  font-weight: 600;
}

.failure-desc {
  display: block;
  margin-top: 8rpx;
  color: #9a3412;
  font-size: 24rpx;
  line-height: 1.6;
}

.retry-btn {
  margin-top: 18rpx;
}

.platform-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 18rpx;
}

.platform-card {
  padding: 22rpx;
  background: #f8fafc;
}

.platform-card.ready {
  background: linear-gradient(160deg, #ecfdf5, #fffdf8);
}

.platform-card.route {
  background: linear-gradient(160deg, #eff6ff, #fffdf8);
}

.platform-card.plan {
  background: linear-gradient(160deg, #f8fafc, #fffdf8);
}

.platform-name {
  display: block;
  color: #111827;
  font-size: 28rpx;
  font-weight: 700;
}

.platform-note {
  display: block;
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 22rpx;
}

.mode-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 18rpx;
}

.mode-item {
  padding: 22rpx 24rpx;
  background: #f8fafc;
}

.mode-title {
  display: block;
  color: #111827;
  font-size: 28rpx;
  font-weight: 700;
}

.mode-desc {
  display: block;
  margin-top: 8rpx;
  color: #4b5563;
  font-size: 24rpx;
  line-height: 1.6;
}
