<view class="page">
  <scroll-view scroll-y class="scroll">
    <view class="hero-shell">
      <view class="hero-glow hero-glow-one"></view>
      <view class="hero-glow hero-glow-two"></view>
      <view class="hero">
        <view class="hero-top">
          <text class="hero-badge">Parse Engine</text>
          <text class="hero-state {{parseState}}">{{parseState === 'failed' ? 'Failed' : parseState === 'success' ? 'Done' : parseState === 'running' ? 'Running' : 'Ready'}}</text>
        </view>
        <text class="hero-title">解析与下载</text>
        <text class="hero-desc">把分享文案、短链和作品地址转成一个清晰可控的去水印任务，而不是黑盒按钮。</text>
      </view>
    </view>

    <view class="notice-card">
      <text class="notice-title">合规提醒</text>
      <text wx:for="{{complianceItems}}" wx:key="*this" class="notice-item">{{item}}</text>
    </view>

    <view class="card">
      <view class="card-head">
        <text class="card-title">输入分享内容</text>
        <text class="card-subtitle">支持分享文案、短链和混合文本</text>
      </view>
      <textarea
        class="input-box"
        placeholder="粘贴分享文案或链接，系统会自动抽取可解析地址"
        value="{{inputUrl}}"
        bindinput="onInputUrl"
        maxlength="800"
        auto-height
      ></textarea>

      <view class="smart-hint">
        <text class="smart-hint-label">当前建议</text>
        <text class="smart-hint-text">{{smartHint}}</text>
      </view>

      <view wx:if="{{analysisHighlights.length}}" class="analysis-grid">
        <view wx:for="{{analysisHighlights}}" wx:key="label" class="analysis-item">
          <text class="analysis-label">{{item.label}}</text>
          <text class="analysis-value">{{item.value}}</text>
        </view>
      </view>

      <view wx:if="{{analysis}}" class="signal-board">
        <view class="signal-row">
          <text class="signal-label">输入类型</text>
          <text class="signal-value">{{analysis.inputModeLabel}}</text>
        </view>
        <view class="signal-row">
          <text class="signal-label">平台识别</text>
          <text class="signal-value">{{analysis.platformLabel}}</text>
        </view>
        <view class="signal-row">
          <text class="signal-label">链接数量</text>
          <text class="signal-value">{{analysis.linkCount}}</text>
        </view>
        <view class="signal-row">
          <text class="signal-label">可解析数量</text>
          <text class="signal-value">{{analysis.supportedCount}}</text>
        </view>
      </view>

      <view wx:if="{{detectedLinks.length}}" class="select-section">
        <text class="sub-title">选择要解析的链接</text>
        <view class="chip-list">
          <view
            wx:for="{{detectedLinks}}"
            wx:key="*this"
            class="chip {{selectedLinkIndex === index ? 'active' : ''}}"
            bindtap="selectDetectedLink"
            data-index="{{index}}"
          >
            链接 {{index + 1}}
          </view>
        </view>
        <view class="clean-card">
          <view class="clean-head">
            <text class="clean-title">清洗结果</text>
            <text class="clean-meta">保留 {{analysis.supportedCount}} 条，可忽略 {{analysis.unsupportedCount}} 条</text>
          </view>
          <view class="platform-summary">
            <text wx:for="{{analysis.platformSummary}}" wx:key="label" class="platform-summary-item">{{item.label}} {{item.count}} 条</text>
          </view>
          <view class="clean-link-list">
            <view wx:for="{{analysis.supportedLinkItems}}" wx:key="url" class="clean-link-item {{selectedLinkIndex === index ? 'active' : ''}}">
              <text class="clean-link-platform">{{item.platformLabel}}</text>
              <text class="clean-link-url">{{item.url}}</text>
            </view>
          </view>
          <view class="clean-actions">
            <text class="clean-action" bindtap="copySelectedDetectedLink">复制当前链接</text>
            <text class="clean-action" bindtap="copyDetectedLinks">复制全部可解析链接</text>
          </view>
        </view>
      </view>

      <view class="select-section">
        <text class="sub-title">选择解析线路</text>
        <view class="chip-list">
          <view
            wx:for="{{routeOptions}}"
            wx:key="id"
            class="chip {{selectedRouteId === item.id ? 'active' : ''}}"
            bindtap="selectRoute"
            data-route-id="{{item.id}}"
          >
            {{item.label}}
          </view>
        </view>
        <view class="route-recommend-card">
          <text class="route-recommend-text">{{routeRecommendation}}</text>
        </view>
        <view class="route-score-list">
          <view wx:for="{{routeOptions}}" wx:key="id" class="route-score-item {{selectedRouteId === item.id ? 'selected' : ''}}">
            <view class="route-score-head">
              <text class="route-score-name">{{item.label}}</text>
              <text class="route-score-badge {{item.recommended ? 'recommended' : ''}}">{{item.recommended ? '推荐' : item.statsBadge}}</text>
            </view>
            <text class="route-score-note">{{item.statsHint}}</text>
          </view>
        </view>
      </view>

      <view class="button-stack">
        <button class="primary-btn" bindtap="onParseCurrent" disabled="{{!inputUrl || parseState === 'running'}}">开始解析</button>
        <button class="secondary-btn" bindtap="onPasteAndParse" disabled="{{parseState === 'running'}}">读取剪贴板并解析</button>
        <button
          wx:if="{{analysis && analysis.supportedCount > 1}}"
          class="batch-btn"
          bindtap="onParseAllDetected"
          disabled="{{parseState === 'running'}}"
        >
          批量解析全部链接（{{analysis.supportedCount}}）
        </button>
      </view>

      <view class="inline-actions">
        <text class="inline-action" bindtap="onClear">清空输入</text>
        <text class="inline-action" bindtap="goToImageEraser">去图片水印</text>
      </view>
    </view>

    <view class="card">
      <view class="card-head">
        <text class="card-title">任务进度</text>
        <text class="status-pill {{parseState}}">{{parseState === 'failed' ? '失败' : parseState === 'success' ? '完成' : parseState === 'running' ? '处理中' : '待开始'}}</text>
      </view>
      <text class="status-desc">{{parseMessage}}</text>

      <view wx:if="{{batchSummary.total > 0}}" class="batch-panel">
        <view class="batch-head">
          <text class="batch-title">批量任务概览</text>
          <text class="batch-current">{{batchSummary.currentText}}</text>
        </view>
        <view class="batch-grid">
          <view class="batch-item">
            <text class="batch-label">总数</text>
            <text class="batch-value">{{batchSummary.total}}</text>
          </view>
          <view class="batch-item">
            <text class="batch-label">已完成</text>
            <text class="batch-value">{{batchSummary.completed}}</text>
          </view>
          <view class="batch-item success">
            <text class="batch-label">成功</text>
            <text class="batch-value">{{batchSummary.success}}</text>
          </view>
          <view class="batch-item failed">
            <text class="batch-label">失败</text>
            <text class="batch-value">{{batchSummary.failed}}</text>
          </view>
        </view>
      </view>

      <view class="timeline">
        <view wx:for="{{progressSteps}}" wx:key="id" class="timeline-item">
          <view class="timeline-node {{item.status}}"></view>
          <view class="timeline-body">
            <text class="timeline-title">{{item.label}}</text>
          </view>
        </view>
      </view>

      <view wx:if="{{routeAttempts.length}}" class="route-panel">
        <text class="route-title">线路回退状态</text>
        <view class="route-list">
          <view wx:for="{{routeAttempts}}" wx:key="id" class="route-item {{item.status}}">
            <view class="route-body">
              <text class="route-name">{{item.label}}</text>
              <text class="route-detail">{{item.detail}}</text>
            </view>
            <view class="route-meta">
              <text class="route-order">{{item.orderText}}</text>
              <text class="route-status">{{item.statusText}}</text>
            </view>
          </view>
        </view>
      </view>

      <view wx:if="{{failureReason}}" class="failure-box">
        <text class="failure-title">失败原因</text>
        <text class="failure-desc">{{failureReason}}</text>
        <button class="retry-btn" bindtap="retryParse">重试当前线路</button>
      </view>

      <button wx:if="{{batchSummary.total > 0 && !batchSummary.active}}" class="task-link-btn" bindtap="goToTaskCenter">去任务页查看结果</button>
    </view>

    <view class="card">
      <view class="card-head">
        <text class="card-title">平台适配状态</text>
        <text class="card-subtitle">识别层已做统一收口</text>
      </view>
      <view class="platform-grid">
        <view wx:for="{{platformReadiness}}" wx:key="name" class="platform-card {{item.state}}">
          <text class="platform-name">{{item.name}}</text>
          <text class="platform-note">{{item.note}}</text>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="card-head">
        <text class="card-title">当前体验重点</text>
        <text class="card-subtitle">让解析过程更可理解、更可控</text>
      </view>
      <view class="mode-list">
        <view wx:for="{{supportModes}}" wx:key="title" class="mode-item">
          <text class="mode-title">{{item.title}}</text>
          <text class="mode-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>
    <view wx:if="{{plannedPlatforms.length}}" class="card">
      <view class="card-head">
        <text class="card-title">下一步规划</text>
        <text class="card-subtitle">后端链路补齐后可继续扩展</text>
      </view>
      <view class="chip-list">
        <text wx:for="{{plannedPlatforms}}" wx:key="*this" class="chip passive">{{item}}</text>
      </view>
    </view>
  </scroll-view>
</view>
