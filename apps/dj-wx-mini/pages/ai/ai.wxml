<view class="page">
  <view class="header">
    <text class="header-title">智能工具箱</text>
    <text class="header-desc">保留当前仍在使用的创作能力</text>
  </view>

  <scroll-view scroll-y class="content">
    <view class="tools-list">
      <view class="tool-card" bindtap="goToTool" data-type="writer">
        <view class="tool-icon purple">
          <text>✍️</text>
        </view>
        <view class="tool-info">
          <text class="tool-name">文案生成</text>
          <text class="tool-desc">智能生成营销文案、标题和发布内容</text>
        </view>
        <text class="tool-arrow">→</text>
      </view>

      <view class="tool-card" bindtap="goToTool" data-type="tts">
        <view class="tool-icon green">
          <text>🎙️</text>
        </view>
        <view class="tool-info">
          <text class="tool-name">配音</text>
          <text class="tool-desc">把文本转换成语音，支持多种音色</text>
        </view>
        <text class="tool-arrow">→</text>
      </view>
    </view>

    <view class="stats-card">
      <text class="stats-title">使用统计</text>
      <view class="stats-grid">
        <view class="stat-item">
          <text class="stat-num">{{stats.aiWrites}}</text>
          <text class="stat-label">文案生成</text>
        </view>
        <view class="stat-item">
          <text class="stat-num">{{stats.aiTts}}</text>
          <text class="stat-label">配音生成</text>
        </view>
      </view>
    </view>

    <view class="tips-section">
      <text class="tips-title">使用提示</text>
      <view class="tip-item">• 文案支持多平台内容风格生成与改写</view>
      <view class="tip-item">• 配音支持较长文本输入，建议分段生成</view>
    </view>
  </scroll-view>
</view>
