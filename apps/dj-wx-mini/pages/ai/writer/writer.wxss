.page {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 120rpx;
  box-sizing: border-box;
}

.content {
  padding: 24rpx 24rpx 24rpx 24rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.card-header .card-title {
  margin-bottom: 0;
}

.char-count {
  font-size: 24rpx;
  color: #999;
}

.textarea {
  width: 100%;
  min-height: 200rpx;
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

/* 平台选择 */
.platform-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.platform-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  border: 4rpx solid transparent;
  transition: all 0.3s;
}

.platform-item.active {
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-color: #667eea;
}

.platform-item.active .platform-name {
  color: #fff;
}

.platform-icon {
  font-size: 44rpx;
  margin-bottom: 10rpx;
}

.platform-name {
  font-size: 22rpx;
  color: #666;
}

/* 风格选择 */
.style-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.style-item {
  padding: 14rpx 28rpx;
  background: #f8f9fa;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  border: 4rpx solid transparent;
  transition: all 0.3s;
}

.style-item.active {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border-color: #667eea;
}

/* 生成按钮 */
.generate-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 50rpx;
  border: none;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 30rpx rgba(102, 126, 234, 0.4);
}

.generate-btn.loading {
  opacity: 0.7;
}

/* 结果 */
.result-card {
  background: #fff;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.result-actions {
  display: flex;
  gap: 30rpx;
}

.action-btn {
  font-size: 28rpx;
  color: #667eea;
}

.result-content {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 30rpx;
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
  white-space: pre-wrap;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.tag {
  font-size: 24rpx;
  color: #667eea;
  background: rgba(102, 126, 234, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

/* 历史 */
.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.clear-btn {
  font-size: 26rpx;
  color: #999;
}

.history-item {
  padding: 24rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.history-item:last-child {
  margin-bottom: 0;
}

.history-topic {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-platform {
  font-size: 24rpx;
  color: #999;
  margin-left: 20rpx;
  flex-shrink: 0;
}
