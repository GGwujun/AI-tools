.page {
  min-height: 100vh;
  background: #f7f8fa;
}

.scroll {
  height: 100vh;
  padding: 20rpx 24rpx 32rpx;
  box-sizing: border-box;
}

.hero-card,
.section-card {
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 12rpx 32rpx rgba(16, 24, 40, 0.06);
}

.hero-card {
  padding: 34rpx 24rpx;
  text-align: center;
}

.fail-figure {
  position: relative;
  width: 116rpx;
  height: 116rpx;
  margin: 0 auto;
}

.fail-sheet {
  position: absolute;
  left: 18rpx;
  top: 8rpx;
  width: 80rpx;
  height: 100rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #eef4ff 0%, #f8fbff 100%);
  box-shadow: inset 0 0 0 2rpx #d7e5ff;
}

.fail-cross {
  position: absolute;
  right: 4rpx;
  bottom: 8rpx;
  width: 46rpx;
  height: 46rpx;
  border-radius: 999rpx;
  background: #f04438;
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 46rpx;
  text-align: center;
}

.hero-title {
  display: block;
  margin-top: 24rpx;
  color: #101828;
  font-size: 34rpx;
  font-weight: 700;
}

.hero-desc {
  display: block;
  margin-top: 14rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.7;
}

.section-card {
  margin-top: 18rpx;
  padding: 24rpx;
}

.section-title {
  display: block;
  color: #101828;
  font-size: 28rpx;
  font-weight: 700;
}

.section-body {
  display: block;
  margin-top: 14rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.8;
}

.primary-btn,
.ghost-btn {
  height: 84rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.primary-btn {
  margin-top: 24rpx;
  background: #1565ff;
  color: #fff;
}

.ghost-btn {
  flex: 1;
  background: #fff;
  color: #475467;
  border: 2rpx solid #e4e7ec;
}

.primary-btn::after,
.ghost-btn::after {
  border: none;
}

.action-row {
  margin-top: 14rpx;
  display: flex;
  gap: 12rpx;
}
