.container {
  padding: 30rpx;
  background: #f5f7fa;
  min-height: 100vh;
}

.converter-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

.label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: block;
}

.input-box {
  border-bottom: 2rpx solid #e8e8e8;
  padding-bottom: 20rpx;
}

.amount-input {
  font-size: 56rpx;
  font-weight: 600;
  color: #333;
  height: 80rpx;
}

.currency-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 40rpx 0;
}

.currency-selector {
  background: #f5f7fa;
  border-radius: 16rpx;
  padding: 24rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.currency-symbol {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.currency-code {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.currency-name {
  font-size: 24rpx;
  color: #999;
}

.arrow {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  color: #999;
}

.swap-btn {
  width: 80rpx;
  height: 80rpx;
  background: #459AD0;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin: 0 20rpx;
}

.result-section {
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 16rpx;
  padding: 40rpx;
  text-align: center;
  color: #fff;
}

.result-label {
  font-size: 24rpx;
  opacity: 0.8;
  display: block;
  margin-bottom: 16rpx;
}

.result-amount {
  font-size: 72rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.result-currency {
  font-size: 28rpx;
  opacity: 0.9;
  display: block;
}

.copy-hint {
  font-size: 22rpx;
  opacity: 0.7;
  margin-top: 16rpx;
  display: block;
}

.common-rates {
  margin-top: 40rpx;
}

.section-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 20rpx;
  display: block;
}

.rate-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.rate-item {
  font-size: 28rpx;
  color: #666;
}

/* 选择器 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.picker-content {
  background: #fff;
  width: 100%;
  border-radius: 30rpx 30rpx 0 0;
  max-height: 70vh;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #e8e8e8;
  font-size: 32rpx;
  font-weight: 600;
}

.picker-list {
  max-height: 60vh;
}

.picker-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.picker-symbol {
  font-size: 40rpx;
  margin-right: 20rpx;
  width: 60rpx;
}

.picker-code {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-right: 20rpx;
  width: 100rpx;
}

.picker-name {
  font-size: 28rpx;
  color: #666;
  flex: 1;
}

.picker-check {
  color: #459AD0;
  font-size: 32rpx;
  font-weight: bold;
}