.page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top center, rgba(21, 101, 255, 0.05), transparent 24%),
    #f7f8fa;
}

.scroll {
  height: 100vh;
  padding: 28rpx 24rpx 24rpx;
  box-sizing: border-box;
}

.header {
  margin-bottom: 24rpx;
}

.header-title {
  display: block;
  color: #101828;
  font-size: 38rpx;
  font-weight: 700;
}

.header-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #98a2b3;
  font-size: 24rpx;
  line-height: 1.6;
}

.grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.tool-card {
  padding: 30rpx 24rpx 26rpx;
  border-radius: 30rpx;
  background: #fff;
  box-shadow: 0 10rpx 28rpx rgba(16, 24, 40, 0.05);
  border: 1rpx solid #eef2f6;
}

.tool-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tool-icon-image {
  width: 44rpx;
  height: 44rpx;
}

.orange { background: #fff3e9; }
.blue { background: #edf4ff; }
.green { background: #eafaf1; }
.purple { background: #f3ecff; }
.pink { background: #fff0f5; }
.indigo { background: #eef2ff; }

.tool-name {
  display: block;
  margin-top: 20rpx;
  color: #101828;
  font-size: 26rpx;
  font-weight: 700;
}

.tool-desc {
  display: block;
  margin-top: 10rpx;
  color: #98a2b3;
  font-size: 22rpx;
  line-height: 1.6;
}
