/* 页面容器 */
.page {
  padding: 20rpx;
  background: #f5f7fa;
  min-height: 100vh;
}

/* 卡片 */
.card {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

/* 表单区域 */
.form {
  width: 100%;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  margin-bottom: 16rpx;
  box-sizing: border-box;
}

.form-btn {
  width: 100%;
  background: #459AD0;
  color: #ffffff;
  font-size: 30rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 8rpx;
  border: none;
  padding: 0;
  margin: 0;
}

.form-btn::after {
  border: none;
  content: none;
}

/* 输出区域 */
.output {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #e0e0e0;
}

.output-img {
  width: 100%;
  height: 400rpx;
  display: block;
  margin-bottom: 16rpx;
}

.output-text {
  width: 100%;
  font-size: 28rpx;
  color: #333;
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
  word-break: break-all;
  box-sizing: border-box;
}

.output-btn {
  width: 100%;
  background: #f0f0f0;
  color: #333;
  font-size: 28rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 8rpx;
  border: none;
  padding: 0;
  margin: 0;
}

.output-btn::after {
  border: none;
  content: none;
}