<view class="page">
  <view class="card">
    <view class="card-title">生成二维码</view>
    <view class="form">
      <input 
        class="form-input" 
        placeholder="请输入文字或链接"
        value="{{inputText}}"
        bindinput="onInput"
      />
      <button class="form-btn" bindtap="generateQR">生成二维码</button>
    </view>
    <view wx:if="{{qrCodeUrl}}" class="output">
      <image class="output-img" src="{{qrCodeUrl}}" mode="aspectFit"></image>
      <button class="output-btn" bindtap="saveQR">保存到相册</button>
    </view>
  </view>
  
  <view class="card">
    <view class="card-title">扫描二维码</view>
    <button class="form-btn" bindtap="scanQR">开始扫描</button>
    <view wx:if="{{scanResult}}" class="output">
      <view class="output-text">{{scanResult}}</view>
      <button class="output-btn" bindtap="copyResult">复制结果</button>
    </view>
  </view>
</view>