page {
  background: #f6f8ff;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
}

button {
  margin: 0;
  padding: 0;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

button::after {
  border: none;
}

.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
